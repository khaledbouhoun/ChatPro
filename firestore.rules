rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read/write their own user document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Secure subcollection permissions for FCM device tokens
      match /fcm_tokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Allow users to create and manage conversations they're part of
    match /conversations/{conversationId} {
      allow read: if request.auth != null && 
        request.auth.uid in resource.data.participants_ids;
      
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants_ids;
      
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants_ids;
      
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.participants_ids;

      // Allow reading and writing messages within a conversation
      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants_ids;
        
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants_ids &&
          request.resource.data.sender_id == request.auth.uid;
        
        // Relax update to allow conversation participants to toggle reactions and status (read receipts)
        allow update: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants_ids;
        
        allow delete: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants_ids &&
          resource.data.sender_id == request.auth.uid;
      }
    }
  }
}
